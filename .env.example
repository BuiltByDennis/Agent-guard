# Database
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/proxy_db

# Redis Cache & Rate Limiting
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET_KEY=generate-a-secret-with-openssl-rand-hex-32

# OpenAI Target
OPENAI_API_KEY=sk-your-openai-api-key
# Observability
SENTRY_DSN=https://your-sentry-dsn

# Security Firewall
FIREWALL_MODE=BLOCK
